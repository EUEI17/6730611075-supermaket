<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>คลังสินค้า - Supermarket Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Sarabun', sans-serif; background-color: #f8f9fa; }
        .navbar { background-color: #28a745 !important; }
        .card-product { border: none; border-radius: 12px; transition: 0.3s; }
        .card-product:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1); }
        .table-custom { background: white; border-radius: 15px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
        .btn-add { background-color: #218838; color: white; border-radius: 8px; }
        .btn-add:hover { background-color: #1e7e34; color: white; }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark mb-4 shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">🌿 Supermarket Admin</a>
            <a href="/add" class="btn btn-add">+ เพิ่มสินค้าใหม่</a>
        </div>
    </nav>

    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold text-dark">รายการสินค้าในคลัง</h2>
            <span class="badge bg-success">อัปเดตล่าสุด: <%= new Date().toLocaleDateString('th-TH') %></span>
        </div>

        <% if (products.length > 0) { %>
            <div class="table-responsive table-custom">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">รูปภาพ</th>
                            <th>ชื่อสินค้า</th>
                            <th>หมวดหมู่</th>
                            <th>ราคา</th>
                            <th>สต็อก</th>
                            <th class="text-center">จัดการ</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% products.forEach(product => { %>
                        <tr>
                            <td class="ps-4">
                                <img src="/uploads/<%= product.image %>" class="rounded" width="50" height="50" style="object-fit: cover;" onerror="this.src='https://via.placeholder.com/50'">
                            </td>
                            <td><span class="fw-bold"><%= product.name %></span></td>
                            <td><span class="badge rounded-pill bg-light text-dark border"><%= product.category %></span></td>
                            <td class="text-success fw-bold"><%= product.price %> ฿</td>
                            <td>
                                <% if(product.stock > 10) { %>
                                    <span class="text-dark"><%= product.stock %> ชิ้น</span>
                                <% } else { %>
                                    <span class="text-danger fw-bold">เหลือเพียง <%= product.stock %> ชิ้น!</span>
                                <% } %>
                            </td>
                            <td class="text-center">
                                <a href="/delete/<%= product.id %>" class="btn btn-sm btn-outline-danger" onclick="return confirm('ยืนยันการลบ?')">ลบ</a>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="text-center py-5 bg-white rounded-4 shadow-sm">
                <div class="mb-3" style="font-size: 50px;">📦</div>
                <h4 class="text-muted">ยังไม่มีข้อมูลสินค้าในระบบ</h4>
                <p class="text-secondary">เริ่มต้นโดยการเพิ่มสินค้าใหม่เข้าระบบได้ที่ปุ่มด้านบน</p>
                <a href="/add" class="btn btn-success px-4">คลิกเพื่อเพิ่มสินค้าแรก</a>
            </div>
        <% } %>
    </div>
</body>
</html>